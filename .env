# ⚠️  TECH TEST ONLY — DO NOT USE IN PRODUCTION
#
# This .env file is intentionally committed so reviewers can run the project
# immediately without any manual configuration.
#
# In a real project:
#   - .env would be in .gitignore
#   - Secrets would live in Azure Key Vault / AWS Secrets Manager / HashiCorp Vault
#   - Local developers would use `dotnet user-secrets` or a secrets manager CLI
#   - CI/CD would inject secrets via pipeline variables

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=nmCsdkhj20n@Sa

# Full connection strings for running APIs outside Docker (dotnet run)
OrderConnectionString=server=localhost;port=3306;user=order-service;password=nmCsdkhj20n@Sa;database=orders;SslMode=None

# ── JWT (leave empty = auth disabled, all endpoints open) ─────────────────────
JWT_AUTHORITY=
JWT_AUDIENCE=orders-api

# ── Redis (V2 only) — leave empty = in-memory fallback ───────────────────────
REDIS_CONNECTION_STRING=

# ── OpenTelemetry (V2 only) — leave empty = console exporter ─────────────────
AZURE_MONITOR_CONNECTION_STRING=
