# Copy this file to .env and fill in the values before running docker compose
# or starting the API locally with `dotnet run`.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Full connection strings used by the APIs at runtime.
# Docker Compose assembles these from DB_PASSWORD automatically (see compose files).
# For `dotnet run` locally, set these env vars in your shell or copy this file to .env:
#   V1: set OrderConnectionString=server=localhost;port=3306;...
#   V2: set OrderConnectionString=server=localhost;port=3306;...

DB_PASSWORD=change_me_before_running

# Local dev overrides (used when running `dotnet run` outside Docker)
# V1
OrderConnectionString=server=localhost;port=3306;user=order-service;password=change_me_before_running;database=orders
# V2 — uncomment and set if running V2 locally without Docker
# OrderConnectionString=server=localhost;port=3306;database=orders;user=order-service;password=change_me_before_running

# JWT configuration (leave empty to disable authentication enforcement in containers)
# In production: set to your Azure AD / AWS Cognito / Keycloak authority URL
JWT_AUTHORITY=
JWT_AUDIENCE=orders-api

# Redis (V2 only) - leave empty to use default (redis:6379 in docker network)
REDIS_CONNECTION_STRING=

# Azure Monitor (V2 only) - optional, leave empty to use console exporter
AZURE_MONITOR_CONNECTION_STRING=
