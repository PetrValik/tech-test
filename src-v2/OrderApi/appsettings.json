{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{ServiceName}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/order-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] [{ServiceName}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "StaleOrderCleanup": {
    "IntervalMinutes": 60,
    "StaleDays": 30
  },
  "OrderConnectionString": "server=localhost;port=3306;database=orders;user=order-service;password=REPLACE_WITH_SECRET",
  "MySqlVersion": "5.7.0-mysql",
  "Jwt": {
    "Authority": "",
    "Audience": "orders-api"
  },
  "Redis": {
    "ConnectionString": ""
  },
  "Otel": {
    "ServiceName": "order-api-v2",
    "Environment": "Development"
  }
}
